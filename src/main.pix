    <Childs>
      <AbstractStep z:Id="i3" i:type="CommentStep">
        <Childs />
        <Id>79e9c878-4f4b-48ef-a4bc-b52ce02c1335</Id>
        <Parent z:Ref="i2" />
        <PropertyValues />
        <SelectedOptionId i:nil="true" />
        <IsCollapsed>false</IsCollapsed>
        <Text>// ===================================================
// Описание:
// Стартовый технический скрипт, отвечающий за инициализацию путей, загрузку фреймворка, проверку технических условий (окна обслуживания, нерабочий день), запуск уведомлений о старте RPA-проекта. Делегирует дальнейшую бизнес-логику во внешние компоненты. Соблюдает принцип минимальной ответственности: выполняет только подготовительные операции, обработку ошибок и завершение процесса.
// ===================================================</Text>
      </AbstractStep>
