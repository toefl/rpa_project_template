                    <d9p1:IsRequired>false</d9p1:IsRequired>
                    <d9p1:Type>Dictionary&lt;System.String, System.Object&gt;</d9p1:Type>
                  </d9p1:ArgumentItem>
                  <d9p1:ArgumentItem z:Id="i14">
                    <d9p1:ArgumentName>message</d9p1:ArgumentName>
                    <d9p1:Description i:nil="true" />
                    <d9p1:Expression>$"[{script_name}] Доступно для добавления: {available_transaction_slots} транзакций."</d9p1:Expression>
                    <d9p1:IsRequired>false</d9p1:IsRequired>
                    <d9p1:Type>System.String</d9p1:Type>
                  </d9p1:ArgumentItem>
