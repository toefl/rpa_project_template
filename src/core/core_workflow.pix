                            <_value xmlns:d15p1="http://www.w3.org/2001/XMLSchema" i:type="d15p1:string">if (retry_counter == max_serial_errors) // Это была последняя попытка
{
    string last_errors = string.Join("\n", errors_history.Select(error =&gt; $"❌{error}"));
    
    throw new Exception($@"Достигнут лимит ({max_serial_errors} шт.) подряд идущих ошибок!
Последние ошибки:
{last_errors}");
}</_value>
