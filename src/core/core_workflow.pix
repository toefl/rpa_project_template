                                <_screenShotBase64 i:nil="true" />
                                <_value xmlns:d17p1="http://www.w3.org/2001/XMLSchema" i:type="d17p1:string">if (transaction["rpa_status"].ToString() == "retrying")
{
    transaction["rpa_status"]   = "retrying";
}
else
{
    transaction["rpa_status"]   = "processing";
}

transaction["rpa_updated_at"] = DateTime.Now;
transaction["rpa_duration_sec"] = 0.0;
transaction["rpa_comment"] = string.Empty;
transaction["rpa_screenshot"] = string.Empty;
transaction["rpa_retries"] = Convert.ToInt32(transaction["rpa_retries"]) + 1;</_value>
                                <_xpathSettings xmlns:d17p1="http://schemas.datacontract.org/2004/07/BR.XPath" i:nil="true" />
