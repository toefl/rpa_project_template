  <Name>core_error_handler.pix</Name>
  <Namespaces xmlns:d2p1="http://schemas.microsoft.com/2003/10/Serialization/Arrays" />
  <Params>
    <Parameter z:Id="i34">
      <DefaultValueExpression>new Dictionary&lt;string, object&gt;()</DefaultValueExpression>
      <Description>Глобальный контекст выполнения приложения. Содержит пути, конфигурации и динамические параметры.</Description>
      <Name>global_context</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.Collections.Generic.Dictionary`2[[System.String, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e],[System.Object, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]</TypeString>
    </Parameter>
    <Parameter z:Id="i35">
      <DefaultValueExpression>default(System.Exception)</DefaultValueExpression>
      <Description>Объект ошибки при транзакционной обработке</Description>
      <Name>transaction_handling_error</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.Exception</TypeString>
    </Parameter>
    <Parameter z:Id="i36">
      <DefaultValueExpression>string.Empty</DefaultValueExpression>
      <Description>Источник ошибки при транзакционной обработке</Description>
      <Name>transactions_error_source</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.String</TypeString>
    </Parameter>
    <Parameter z:Id="i37">
      <DefaultValueExpression>-1</DefaultValueExpression>
      <Description>Счетчик текущих попыток</Description>
      <Name>retry_counter</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.Int32</TypeString>
    </Parameter>
    <Parameter z:Id="i38">
      <DefaultValueExpression>3</DefaultValueExpression>
      <Description>Максимальное число подряд идущих ошибок перед прерыванием процесса робота</Description>
      <Name>max_serial_errors</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.Int32</TypeString>
    </Parameter>
    <Parameter z:Id="i39">
      <DefaultValueExpression>new List&lt;string&gt;()</DefaultValueExpression>
      <Description>Список накопленных ошибок при обработке (N подряд)</Description>
      <Name>errors_history</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.Collections.Generic.List`1[[System.String, System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]</TypeString>
    </Parameter>
    <Parameter z:Id="i40">
      <DefaultValueExpression>string.Empty</DefaultValueExpression>
      <Description>Сообщение об ошибке при транзакционной обработке</Description>
      <Name>transactions_error_message</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.String</TypeString>
    </Parameter>
    <Parameter z:Id="i41">
      <DefaultValueExpression>string.Empty</DefaultValueExpression>
      <Description>Скриншот ошибки по текущей попытке</Description>
      <Name>screenshot_retry_counter_file</Name>
      <RunnerType>None</RunnerType>
      <TypeString>System.String</TypeString>
    </Parameter>
