                                    <PropertyName>Value</PropertyName>
                                    <_dataType>Expression</_dataType>
                                    <_expression>$"&lt;p&gt;Возникло бизнес-исключение: \"Просроченные документы (срок действия менее 30 дней)\" для транзакции \"{((DataRow)transaction_info["transaction"])["id"].ToString()}\".&lt;br&gt;Текущий счетчик попыток \"{(int)transaction_info["retry_counter"]}\"&lt;/p&gt;"</_expression>
