                                  <PropertyValue z:Id="i34">
                                    <PropertyName>CSCode</PropertyName>
                                    <_dataType>Value</_dataType>
                                    <_expression i:nil="true" />
                                    <_screenShotBase64 i:nil="true" />
                                    <_value xmlns:d19p1="http://www.w3.org/2001/XMLSchema" i:type="d19p1:string">DataRow transaction = (DataRow)transaction_info["transaction"];
transaction["rpa_screenshot"] = screenshot_transaction_file;

//Имеет смысл сохранять в словарь только если требуется отправить письмо
//Используется в `send_report.pix`
global_context["screenshot_transaction_file"] = screenshot_transaction_file; </_value>
                                    <_xpathSettings xmlns:d19p1="http://schemas.datacontract.org/2004/07/BR.XPath" i:nil="true" />
                                  </PropertyValue>
